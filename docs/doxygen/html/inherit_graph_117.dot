digraph "Graphical Class Hierarchy"
{
 // LATEX_PDF_SIZE
  bgcolor="transparent";
  edge [fontname=Helvetica,fontsize=10,labelfontname=Helvetica,labelfontsize=10];
  node [fontname=Helvetica,fontsize=10,shape=box,height=0.2,width=0.4];
  rankdir="LR";
  Node0 [id="Node000000",label="std::runtime_error",height=0.2,width=0.4,color="grey60", fillcolor="#E0E0E0", style="filled",tooltip=" "];
  Node0 -> Node1 [id="edge135_Node000000_Node000001",dir="back",color="steelblue1",style="solid",tooltip=" "];
  Node1 [id="Node000001",label="RailwayParserException",height=0.2,width=0.4,color="grey40", fillcolor="white", style="filled",URL="$class_railway_parser_exception.html",tooltip="Classe de base pour toutes les erreurs du parseur ferroviaire."];
  Node1 -> Node2 [id="edge136_Node000001_Node000002",dir="back",color="steelblue1",style="solid",tooltip=" "];
  Node2 [id="Node000002",label="InvalidGeoJsonFormatException",height=0.2,width=0.4,color="grey40", fillcolor="white", style="filled",URL="$class_invalid_geo_json_format_exception.html",tooltip="Levée quand le fichier GeoJSON est malformé ou ne contient aucune géométrie LineString exploitable."];
  Node1 -> Node3 [id="edge137_Node000001_Node000003",dir="back",color="steelblue1",style="solid",tooltip=" "];
  Node3 [id="Node000003",label="InvalidSwitchConfigException",height=0.2,width=0.4,color="grey40", fillcolor="white", style="filled",URL="$class_invalid_switch_config_exception.html",tooltip="Levée quand un aiguillage viole une contrainte géométrique du CDC."];
  Node1 -> Node4 [id="edge138_Node000001_Node000004",dir="back",color="steelblue1",style="solid",tooltip=" "];
  Node4 [id="Node000004",label="InvalidTopologyException",height=0.2,width=0.4,color="grey40", fillcolor="white", style="filled",URL="$class_invalid_topology_exception.html",tooltip="Levée quand la topologie du graphe parsé est structurellement incohérente."];
}
